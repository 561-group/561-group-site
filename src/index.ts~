import { htmlRepr, jsonRepr, textRepr, type App } from "@561-group/web-server";
import { render } from "@561-group/web-theming";
import { fiveSixOneTheme } from "@561-group/561-group-web-theme";

export function create561GroupSiteApp(): App {
  return {
    security: true,
    cacheControl: { visibility: "public", maxAge: 300 },
    resources: [
      {
        id: "home",
        match: "/",
        methods: ["GET"],
        produces: ["text/html"],
        handler: (ctx) => htmlRepr(renderHome(ctx.nonce), { status: 200 }),
      },
      {
        id: "site-json",
        match: "/site.json",
        methods: ["GET"],
        produces: ["application/json"],
        handler: () => jsonRepr(siteJson(), { status: 200 }),
      },
      {
        id: "healthz",
        match: "/healthz",
        methods: ["GET"],
        produces: ["text/plain"],
        handler: () => textRepr("ok\n", { status: 200, cacheControl: { noStore: true } }),
      },
    ],
  };
}

function siteJson() {
  return {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "The 561 Group",
    url: "https://561.group/",
    description: "An autonomous confederacy pursuing Black Liberation and Indigenous Sovereignty.",
  };
}

function renderHome(nonce: string): string {
  const article = `<p class="lede">We coordinate autonomous work for Black Liberation and Indigenous Sovereignty.</p>`;
  return render(fiveSixOneTheme, article, {
    nonce,
    title: "The 561 Group",
    siteName: "The 561 Group",
    description: "An autonomous confederacy pursuing Black Liberation and Indigenous Sovereignty.",
    canonical: "https://561.group/",
    lang: "en",
    year: 2026,
  });
}
