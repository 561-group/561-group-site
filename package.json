{
  "name": "@561-group/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deployable 561.group apex site.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/561-group/561-group-site.git"
  },
  "scripts": {
    "build:worker": "node scripts/build-worker.mjs",
    "serve": "node src/server.ts",
    "test": "node --test test/verify-ephemeris-offer.test.mjs",
    "check": "tsc --noEmit && node --test test/verify-ephemeris-offer.test.mjs",
    "verify:ephemeris-offer": "node scripts/verify-ephemeris-offer.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@emsenn/561-group-website-theme": "workspace:*",
    "@emsenn/http-server": "workspace:*",
    "@emsenn/organizing-with-the-semantic-web": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "sideEffects": false,
  "keywords": [
    "sovereign-state-enterprise",
    "open-source",
    "x402",
    "sponsorship"
  ]
}
