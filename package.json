{
  "name": "@emsenn/561-group-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Deployable 561.group apex site.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emsenn/561-group-site.git"
  },
  "scripts": {
    "serve": "node src/server.ts",
    "test": "node --test \"src/**/*.test.ts\"",
    "check": "tsc --noEmit",
    "verify": "pnpm run check && pnpm run test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@emsenn/561-group-website-theme": "workspace:*",
    "@emsenn/computing-with-the-web": "workspace:*",
    "@emsenn/http-server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "sideEffects": false
}
