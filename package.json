{
  "name": "@561-group/561-group-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Deployable 561.group apex site.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emsenn/561-group-site.git"
  },
  "scripts": {
    "serve": "node src/server.ts",
    "test": "node --test \"src/**/*.test.ts\"",
    "check": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@561-group/web-server": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "sideEffects": false,
  "561:serve": {
    "domain": "561.group",
    "kind": "proxy",
    "port": 18788,
    "sse": false,
    "ws": false
  }
}
